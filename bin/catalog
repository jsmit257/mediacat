#!/bin/sh

shopt -s lastpipe
set -o pipefail

alias info='echo -e "\x1b[1;32minfo\x1b[0m"'
alias warn='echo -e "\x1b[1;33mwarn\x1b[0m"'
alias err='echo -e "\x1b[1;31merror\x1b[0m"'
alias fatal='echo -e "\x1b[1;37;41mfatal\x1b[0m"'
alias sqlinfo='echo -e ".print \x1b[1;32minfo\x1b[0m"'
alias sqlwarn='echo -e ".print \x1b[1;33mwarn\x1b[0m"'
alias sqlerr='echo -e ".print \x1b[1;31merror\x1b[0m"'
alias sqlfatal='echo -e ".print \x1b[1;37;41mfatal\x1b[0m"'
alias probetags='ffprobe -v quiet -output_format json -show_entries format_tags'

readlink -f "`dirname "$0"`/.." | read homedir

read -d '' tagjq<<-'EOF'
.format.tags // {}
| del(
	.major_brand,
	.minor_version,
	.compatible_brands,
	.encoder
)
EOF

. "`dirname "$0"`/logrotate"

function childids() {
	local ppid="$1"
	local depth="${2:-0}"
	local pid

	ps -o pid= --ppid "$ppid" | while read pid; do
		echo "$depth $pid"
		childids "$pid" "$[depth+1]"
	done
}

function cleanup() {
	local rundir="${homedir}/run$1"
	local pidfile children

	trap - TERM INT PIPE

	find "$rundir" -maxdepth 1 -type f | read pidfile

	cat "$pidfile" | readarray -t children

	rm "$pidfile"

	kill -TERM "${children[@]}"
}

function ckrunning() {
	local rundir="${homedir}/run$1"
	local pid

	test -d "$rundir" || return 1

	find "$rundir" -maxdepth 1 -type f -printf "%f" | read pid

	if test -z "$pid"; then
		return 1
	elif ! ps -p "$pid" 1>/dev/null 2>&1; then
		warn "process '$pid' in '$rundir' is not running"
		rm "$rundir/$pid"
		return 1
	elif test -z "$CAT_FORCED"; then
		fatal "a process [$pid] is already listening on '$1'" >&3
		return
	fi

	childids "$pid" | sort -r -k1 | cut -f2 -d' ' >"$rundir/$pid"
	kill -TERM "$pid" && return 1 || return 0
}

function diffnames() {
	local -a result=()
	local name exists

	for name in "$@"; do
		for exists in "${tagnames[@]}"; do
			test "$name" == "$exists" && continue 2
		done

		result+=("$name")
	done

	test "${#result[@]}" -eq 0 && return

	printf "%s\n" "${result[@]}"
}

function createnames() {
	local name

	for name in "$@"; do
		# we won't have to ignore a value more than once per thread,
		# but there's no other way to win the race when we don't
		# have semaphores
		echo "insert or ignore into tagnames(tagname) values('$name');"
	done
}

function inserttags() {
	local inode="$1"
	local name value
	shift

	jq -r 'to_entries[] | "\(.key) \(.value)"' <<<"$@" \
	| while read name value; do
		cat - <<-EOF
		insert  into tagvalues(tagvalue, inode, tagnameid)
		select  '${value//\'/\'\'}'
		       ,$inode
		       ,tn.id
		  from  tagnames tn
		 where  tn.tagname = '$name'
		;
		EOF
	done
}

function createpaths() {
	local root="${1//\'/\'\'}"
	local pathparts part

	echo "${2#$root/}" | IFS=/ read -a pathparts

	for part in "${pathparts[@]}"; do
		part="${part//\'/\'\'}"
		cat - <<-EOF
		insert or ignore into paths(name, parentid)
		select  '$part'
		       ,id
		  from  fullpaths
		 where  fullpath = '$root'
		;
		EOF

		root="$root/$part"
	done
}

function createfile() {
	local file="${1//\'/\'\'}"
	local inode="$2"

	cat - <<-EOF
	insert into files(id, inode)
	select  fp.id
	       ,$inode
	  from  fullpaths fp
	 where  fp.fullpath = '$file'
	returning 'created file', '$inode', '$file'
	;
	EOF
}

function closewrite() {
	local root="$1"
	local inode="$2"
	local file="$3"
	local tags tempnames newnames lastinode

	read lastinode

	if test "$inode" -ne "${lastinode:-0}"; then
		# poor-man's test for a media file; don't create inode if this fails
		if ! probetags "$file" | jq -c "$tagjq" | read tags; then
			sqlwarn "failed to read tags from '$file'"
			return 1
		fi

		echo "insert into inodes(inode) values($inode);"

		if test "$tags" == '{}'; then
			sqlwarn  "no tags found in file '$file'"
		elif ! echo "$tags" | jq -r 'keys[]' | readarray -t tempnames; then
			fatal "failed to extract tag names from '$tags' for '$file'" >&3
		elif ! diffnames "${tempnames[@]}" | readarray -t newnames; then
			sqlwarn "couldn't difference tag names" # this won't happen
		elif ! createnames "${newnames[@]}"; then
			sqlerr "couldn't create statements for new tagnames '${newnames[@]}'"
		elif ! inserttags "$inode" "$tags"; then
			fatal "couldn't create statements for new tagvalues" >&3
		else
			sqlinfo "added ${#tempnames[@]} tags for '$inode'"
		fi

		tagnames+=("${newnames[@]}")
	fi

	createpaths "$root" "$file"

	# XXX: this fails referential integrity on some unlikely scenario where
	#      there are multiple links to a non-media file
	createfile "$file" "$inode"
}

function createdb() {
	local dir="$1"
	local db="$2"

	test -e "$db" && {
		info "removing existing database file \c"
		rm -v "$db"
	} >&2

	cat "${homedir}/etc/createdb.sql" - <<-EOF|
	insert into paths(name) values('$dir');
	EOF
	sqlite3 -bail "$db" || return 1

	syncdb "$dir" "$db"
}

function remove() {
	local file="$1"
	local inode="$2"
	local linkcount

	read linkcount

	cat - <<-EOF
	delete  from files
	 where  id = (
	  select  fp.id
	    from  fullpaths fp
	   where  fp.fullpath = '$file')
	;
	delete  from paths
	 where  id = (
	  select  fp.id
	    from  fullpaths fp
	   where  fp.fullpath = '$file')
	;
	.print removed references to '$file'
	EOF

	test "${linkcount:-0}" -lt 2 && cat - <<-EOF
	delete  from tagvalues
	 where  inode = '$inode'
	;
	delete  from inodes
	 where  inode = '$inode'
	;
	`sqlinfo "removed inode $inode and values for '$file'"`
	EOF
}

function moveddirto() {
	dir="$1"
	oldid="$2"

	if test -n "$oldid"; then
		# for simple renaming we could just update the name in paths,
		# but when the directory has moved around in the tree it gets
		# more complicated; unconditional create and update is sorta
		# ham-fisted, and it leaves an orphan, but the cleanup proc
		# will fix it
		cat - <<-EOF
		update  paths
		   set  parentid = (
		  select  fp.id
		    from  fullpaths fp
		   where  fp.fullpath = '$dir')
		 where  parentid = $oldid
		;
		EOF
	else
		# an amalgam of syncdb and movefileto that indexes new files,
		# but checks each inode one at a time, instead of relying on
		# the sorted order of the list for finding duplicate inodes
		#  when moving on the same filesystem; when copying or moving
		# from a different filesystem, this is a no-op, but close_write
		# will pick up new files one at a time
		find "$dir" -type f -printf "%i %p\n" \
		| while read inode file; do
			echo "select inode from inodes where inode = $inode" \
			| sqlite3 -readonly "$db" \
			| closewrite "$dir" "$inode" "$file"
		done
	fi
}

function movedfileto() {
	dir="$1"
	file="$2"
	inode="$3"
	oldid="$4"

	if test -n "$oldid"; then
		cat - <<-EOF
		update  files
		   set  id = (
		  select  fp.id
		    from  fullpaths fp
		   where  fp.fullpath = '$file')
		 where  id = $oldid
		;
		EOF
	else
		echo "select inode from inodes where inode = $inode" \
		| sqlite3 -readonly "$db" \
		| closewrite "$dir" "$inode" "$file"
	fi
}

function movedto() {
	local dir="$1"
	local file="$2"
	local inode="$3"
	local filetype="$4"
	local oldid

	read oldid

	test -n "$oldid" && createpaths "$dir" "$file"

	if test "$filetype" == "d"; then
		moveddirto "$file" "$oldid"
	else
		movedfileto "$dir" "$file" "$inode" "$oldid"
	fi

	cat - <<-EOF
	delete  from transients
	 where  cookie = '$cookie'
	;
	`sqlinfo "finished move_to event for '$file'"`
	EOF
}

function cleandb() {
	db="$1"
	local now file inode linkcount

	echo ".print `info "starting cleanup"`"

	date +"%s" | read now

	cat - <<-EOF|
	select  file
	       ,inode
	       ,linkcount
	  from  pruned
	 where  $now - unixepoch(created) > 5
	EOF
	sqlite3 -readonly "$db" \
	| while IFS='|' read file inode linkcount; do
		remove "$file" "$inode" <<<"$linkcount"
	done

	cat - <<-EOF
	delete  from transients
	 where  $now - unixepoch(created) > 5
	returning 'removed aged transient', *
	;
	delete  from paths
	 where  exists (
	   select  1
	     from  orphans o
	    where  o.id = paths.id)
	returning 'removed path', *
	;
	`sqlinfo "swept old records and orphans"`
	EOF
}

function syncdb() {
	local root="$1"
	local db="$2"
	local inode file lastinode=0 currlinks=0

	{
		echo "begin transaction;"

		find "$root" -type f -printf "%i %p\n" \
		| while read inode file; do
			echo "insert into sync(inode, pathname) values($inode, '$file');";
		done

		echo "commit;"
	} | sqlite3 -bail "$db" || return 1

	{
		echo "begin transaction;"

		echo "select inode, inodepath, linkcount from removed order by inode" \
		| sqlite3 -readonly "$db" \
		| while IFS='|' read inode file linkcount; do
			test "$inode" -ne "$lastinode" && currlinks="$linkcount" || let currlinks--
			remove "$file" "$inode" <<<"$currlinks"
			lastinode="$inode"
		done

		echo "commit;"
	} | sqlite3 -bail "$db" || return 1

	lastinode=0
	{
		echo "begin transaction;"

		echo "select inode, pathname, tagged from unsynced order by inode" \
		| sqlite3 -readonly "$db" \
		| while IFS='|' read inode file tagged; do
			test "$tagged" -gt 0 && lastinode="$inode"
			closewrite "$root" "$inode" "$file" <<<"$lastinode"
			lastinode="$inode"
		done

		echo "commit;"
	} | sqlite3 -bail "$db" || return 1

	cleandb "$db" | sqlite3 -bail "$db" || return 1

	cat - <<-EOF|
	delete from sync;
	vacuum;
	`sqlinfo "finished sync '$db' on dir '$root'"`
	EOF
	sqlite3 -bail "$db" || return 1
}

function listen() {
	local dir="$1"
	local db="$2"
	local logdir="$3"
	local events cookie file inode filetype

	trap 'cleanup "$dir"' TERM INT PIPE

	exec 1>>"$logdir/listen.log" 2>&1
	exec 3> >(tee -a "$logdir/fatal.log")

	roller "$logdir" &

	echo "select tagname from tagnames" | sqlite3 -readonly "$db" | readarray -t tagnames

	inotifywait -m -r -e create -e close_write -e move -e delete --format "%e %c %w%f" "$dir" \
	| while read events cookie file; do
		[[ "$events" == *ISDIR* ]] && filetype=d || filetype=f
		
		if ! stat --printf "%i" "$file" 2>/dev/null; then
			# this happens on DELETE and MOVED_FROM; directories don't care
			# about inodes (or subsequent linkcounts)
			echo "select inode from inodepaths where inodepath = '$file'" \
			| sqlite3 -readonly "$db"
		fi | read inode

		events="CLEAN_DB,${events/,ISDIR}"

		while read event; do
			case "$event" in
				CREATE) test "$filetype" == f -a "`stat --printf "%h" "$file"`" != "1" &&
				echo "select inode from inodes where inode = $inode" \
				| sqlite3 -readonly "$db" \
				| closewrite "$dir" "$inode" "$file"
				;;

				DELETE) test "$filetype" == d ||
				echo "select count(1) from files where inode = $inode" \
				| sqlite3 -readonly "$db" \
				| remove "$file" "$inode"
				;;

				CLOSE_WRITE) closewrite "$dir" "$inode" "$file" <<<0 ;;

				MOVED_FROM) cat - <<-EOF
				insert into transients(cookie, oldpath)
				select  '$cookie'
				       ,id
				  from  fullpaths
				 where  fullpath = '$file'
				returning 'created transient', *
				;
				EOF
				;;

				MOVED_TO) cat - <<-EOF|
				select  oldpath
				  from  transients
				 where  cookie = '$cookie'
				EOF
				sqlite3 -readonly "$db" | movedto "$dir" "$file" "$inode" "$filetype"
				;;

				CLEAN_DB) cleandb "$db" ;;
			esac | sqlite3 -bail "$db" >&2
		done <<<"${events//,/$'\n'}"
	done
} >&2

for arg in "$@"; do
	case "$arg" in
	"-nolisten") CAT_NO_LISTEN=1; continue ;;

	"-force") CAT_FORCED=1; continue ;;

	"-halt") CAT_NO_LISTEN=1 CAT_FORCED=1 ;;&

	-*) test -n "$CAT_COMMAND" && {
		fatal "only one of -rebuild, -sync or -halt is allowed per directory"
		fatal "command is already set to '$CAT_COMMAND'"
		exit 1
	}
	CAT_COMMAND="${arg#-}"
	continue ;;
	esac

	readlink -f "$arg" | read dir

	test -d "$dir" || {
		fatal "'$dir' from '$arg'  does not specify a directory"
		exit 1
	}

	logdir="${homedir}/log$dir"
	test -d "$logdir" || mkdir -vp "$logdir" || {
		fatal "'$logdir' is not a directory and couldn't be created"
		exit 1
	}
	exec 3> >(tee "$logdir/fatal.log")

	dbdir="${homedir}/data$dir"
	test -d "$dbdir" || mkdir -vp "$dbdir" || {
		fatal "'$dbdir' is not a directory and couldn't be created" >&3
		exit 1
	}
	db="$dbdir/data.db"

	test ! -f "$db" -a "$CAT_COMMAND" != 'halt' && CAT_COMMAND=rebuild

	if ckrunning "$dir"; then
		fatal "failed to execute '${CAT_COMMAND:-listener}'; an instance is still running for '$dir'" >&3
		exit 1
	fi

	case "$CAT_COMMAND" in
	'halt') info "halted listener for '$dir'" ;;

	'rebuild') createdb "$dir" "$db" || {
		fatal "failed to create database" >&3
		exit 1
	} 2>&1 | tee "$logdir/build.log" ;;

	'sync') syncdb "$dir" "$db" || {
		fatal "failed to sync database" >&3
		exit 1
	} 2>&1 | tee "$logdir/sync.log" ;;

	*) test -n "$CAT_COMMAND" && {
		fatal "unrecognized command '$CAT_COMMAND'" >&3
		exit 1
	} ;;
	esac

	exec 3>&-

	if test -z "$CAT_NO_LISTEN"; then
		mkdir -vp "${homedir}/run$dir"
		listen "$dir" "$db" "$logdir" &
		touch "${homedir}/run$dir/$!"
	fi

	unset CAT_COMMAND CAT_NO_LISTEN CAT_FORCED
done >&2

info "success $$"

