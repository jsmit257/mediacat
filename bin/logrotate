#!/bin/sh

: "${MAX_LOGS:=5}"
: "${MAX_LOG_SIZE:=1048576}"

function log() {
	while read -d $'\n' line; do
		echo "`date --iso-8601=seconds` $line"
	done
}

function roller() {
	inotifywait -m -e close_write --format "%w%f" "$1" \
	| while read log; do
		[[ "$log" == *.log.[0-9]* ]] && continue

		test "`du -b "$log" | cut -f1`" -lt "$MAX_LOG_SIZE" && return

		for i in `seq "$MAX_LOGS" -1 2`; do
			test -f "$log.$[i-1]" && cat "$log.$[i-1]" >"$log.$i"
		done

		cat "$log" >"$log.1"

		truncate -s 0 "$log"
	done
}

