#!/bin/sh
#
# query a database created by the catalog script (see below) and return results
# as YAML like the following:
# 'inode':
#   files:
#     - fileName1
#     ...
#   tags:
#     tag: value
#     ...
# ...
#
# results are objects indexed by inode number, containing a list of files linked
# to the inode, and a list of metadata tags extracted from then inode
#
# usage: findmedia [-help] /watched/directory criterion [and|or] ...
#
# -help: print this help and exit, no other processing is performed
#
# /watched/directory is the name of a directory that was previously indexed by
# the catalog script (see below); an error is returned if no database exists
#
# criteria are either 'name' or 'value', followed by either '=' (for exact match),
# or '%'/'%%' (for a sql `like` pattern match), followed by the pattern to match; e.g.
# - name=date: matches all tags named date
# - value="Tag Value" matches all tags with the exact value 'Tag Value'
# - value%"%pattern_" matches all tags that contain zero or more chars ('%'),
#   followed  by 'pattern' (case-insensitive) followed by exactly one char ('_')
#   (i.e. `where tagvalue like '%pattern_'`); if the operator is '%%' then the
#   pattern portion is wrapped in '%' chars, so value%%pattern resolves to
#   `tagvalue like '%pattern%'`
#
# use 'and', 'or' and 'not' between criteria to further refine the search conditions
# - 'and' is optional and implied when criteria appear consecutively; e.g.
#   `name=date value%"2012%"` translates to:
#   `where tagname = 'date' and tagvalue like '2012%'`
# - the 'or' conjunction must be specified explicitly
# - 'not' modifies the preceeding 'or' or (implicit) 'and'
#
# it is not recommended to use 'name=tagname' without a corresponding 'value...'
# criterion as this will likely return a prohibitively long result, but this is
# not enforced; there is no way to query for `is null` because neither names nor
# values can ever be null
#
# see also: catalog (https://github.com/jsmit257/mediacat/blob/master/bin/catalog)
#

[[ " $* " =~ .*" -help ".* ]] && {
	sed -r '2,/^$/ !d; s/^# ?//' "$0"
	exit
}

shopt -s lastpipe
set -o pipefail

function operate() {
	op="${1:0:1}"
	val="${1:1}"

	case "$op" in
	'=') echo "= '$val'" ;;
	'%')
		test "${val:0:1}" == '%' && val="${val}%"
		echo "like '$val'" ;;
	*)
		echo "unknown conditional operator '${1[0]}'" >&2
		exit 1 ;;
	esac
}

function parsearg() {
	local arg="${1//\'/\'\'}"

	case "$arg" in
	name*) echo "tagname `operate "${arg#name}"`" ;;
	value*) echo "tagvalue `operate "${arg#value}"`" ;;
	*)
		echo "arguments must start with 'name' or 'value', not '$arg'" >&2
		exit 1 ;;
	esac
}

readlink -f "$1" | read dir
readlink -f "`dirname "$0"`/.." | read homedir

read -d '' fmtjq <"$homedir/etc/fmt.jq"

db="${homedir}/data/$dir/data.db"
test -f "$db" || {
	echo "'$dir' is not a watched directory"
	exit 1
} >&2

shift

test "${#@}" -eq 0 && {
	echo "at least one WHERE condition is required"
	exit 1
} >&2

while test -n "$1"; do
	arg="$1"
	shift

	case "$arg" in
	'or'|'and') conjunction=" $arg" ;;&
	'not') conjunction="$conjunction $arg" ;;&
	'or'|'and'|'not') continue ;;
	esac

	where+="$conjunction `parsearg "$arg"`"

	conjunction=" and"
done

test -n "$nodetail" && {
	noaudio=1
	novideo=1
}

test -n "$noaudio" && filter=".[].audio"
test -n "$novideo" && filter+="${filter:+,}.[].video"
test -n "$filter"  && filter="del($filter)"

cat<<-EOF|
with taginodes(inode) as (
	select  distinct
	        inode
	  from  tags
	 where  $where
)
select  *
  from  filetags  ft
  join  taginodes ti
    on  ft.inode  = ti.inode
EOF
sqlite3 -readonly -bail -json "$db" | jq "$fmtjq" | yq -y "${filter:-.}"

