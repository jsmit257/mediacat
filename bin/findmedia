#!/bin/sh

shopt -s lastpipe

read -d '' fmt<<-'EOF'
group_by(.inode)
| map(
	foreach .[] as $file (
		{};
		. *= {
			key: $file.inode | tostring,
			value: {
				files: (.value.files) + [$file.fullname],
				tags: { ($file.tagname): $file.tagvalue }
			}
		};
		{
			key: .key,
			value: {
				files: .value.files | unique,
				tags: .value.tags
			}
		}
	)
)
| from_entries
EOF

readlink -f "$1" | read dir
test -n "$dir" || {
	echo "'$1' is not a valid directory"
	exit 1
} >&2

readlink -f "`dirname "$0"`/.." | read homedir

db="${homedir}/data/$dir/data.db"
test -f "$db" || {
	echo "'$dir' is not a watched directory"
	exit 1
} >&2

shift

test "${#@}" -eq 0 && {
	echo "at least one WHERE condition is required"
	exit 1
} >&2

cat<<-EOF|
with inodes(inode) as (
	select  distinct
	        inode
	  from  tags
	 where  $@
)
select  *
  from  filetags ft
  join  inodes i
    on  ft.inode = i.inode
EOF
sqlite3 -readonly -bail -json "$db" | jq "$fmt"

