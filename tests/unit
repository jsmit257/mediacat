#!/bin/sh

shopt -s lastpipe
set -o pipefail

cd "`dirname "$0"`"

mkdir ./sample 2>/dev/null

readlink -f ./sample | read watched

db="../data$watched/data.db" # FIXME: should come from catalog

alias debug='echo -e "\x1b[1;36mdebug\x1b[0m"'
alias start='echo -e "\n\x1b[1;33mstarting\x1b[0m ${FUNCNAME[0]}"'
alias pass='echo -e "\x1b[1;35mpassed\x1b[0m ${FUNCNAME[0]}"'
alias fail='echo -e "\x1b[1;31mfailed\x1b[0m pgid($$)"'

alias nodaemon='../bin/catalog -nolisten'
alias query='sqlite3 -bail -readonly -json "$db"'
alias findmedia='../bin/findmedia "$watched"'

jqcompare='if ($expected | sort) != . then error("unexpected results") else "pass" end'
jqnotcontains='if contains($exclude) then error("path(s) not removed") else "pass" end'

# create sample video with metadata tags from a 1x1px image file
function vidgen() {
	dst="$1.mp4"
	shift

	args=("$@")
	for i in `seq 0 2 "${#args[@]}"`; do
		args[i+1]="${args[i]}=${args[i+1]/\'/\'\'}"
		args[i]=-metadata
	done

	ffmpeg \
		-nostdin \
		-hide_banner \
		-nostats \
		-v error \
		-i px.gif \
		-f lavfi \
		-i anullsrc=sample_rate=44000:channel_layout=5.1 \
		-c:v hevc \
		-x265-params log-level=error \
		-pix_fmt yuv420p \
		-s 50:50 \
		-c:a aac \
		-shortest \
		-loop 1 \
		"${args[@]}" \
		"pool/$dst"
}

# ensure all the directories and sample files exist
function sanity() {
	start "- setting up the test environment"
	rm -fr "$watched"/* ./pool/*

	mkdir -vp pool "$watched"/{foo/{bar,quux},one/two/three} &&
	vidgen agaric title "Do NOT Eat" artist "Fly Agaric" &&
	vidgen liberty artist "Ben Franklin" description "The OG" &&
	vidgen morel description "Good Luck Finding Them" comment "Gourmet" &&
	vidgen muertos comment "Like it's 1999" date "1999.12.31" &&
	vidgen phosphor date "1970.01.01" title "Unix Epoch" &&
	ln -v pool/{agaric,morel,phosphor}.mp4 "$watched" || return 1

	pass "- setting up the test environment"
}

function allpathnames() {
	echo "select * from paths" \
	| query \
	| jq '[.[].name] | sort' \
	| tee >(cat >&2)
}

function inodepaths() {
	echo "select * from inodepaths" \
	| query \
	| jq '[.[].inodepath] | sort' \
	| tee >(cat >&2)
}

function findmediafiles() {
	findmedia "$@" | yq '.[].files' | tee >(cat >&2)
}

function rebuild() {
	read -d '' inodepaths<<-EOF
	[
	  "$watched/agaric.mp4",
	  "$watched/phosphor.mp4",
	  "$watched/morel.mp4"
	]
	EOF

	start "- expected inodepaths: $inodepaths"

	nodaemon -rebuild "$watched" || {
		fail "executing rebuild"
		return 1
	}

	inodepaths | jq --argjson expected "$inodepaths" -r "$jqcompare" || return 1

	pass
}

function link_one_from_pool() {
	read -d '' inodepaths<<-EOF
	[
	  "$watched/agaric.mp4",
	  "$watched/phosphor.mp4",
	  "$watched/foo/bar/liberty.mp4",
	  "$watched/morel.mp4"
	]
	EOF

	start "- expected inodepaths: $inodepaths"

	ln -v "pool/liberty.mp4" "$watched/foo/bar"

	nodaemon -sync "$watched" || {
		fail "executing link_one_from_pool"
		return 1
	}

	inodepaths | jq --argjson expected "$inodepaths" -r "$jqcompare" || return 1

	pass
}

function remove_file_in_tree() {
	read -d '' inodepaths<<-EOF
	[
	  "$watched/agaric.mp4",
	  "$watched/phosphor.mp4",
	  "$watched/foo/bar/liberty.mp4"
	]
	EOF

	start "- expected inodepaths: $inodepaths"

	rm -v "$watched/morel.mp4"

	nodaemon -sync "$watched" || {
		fail "executing remove_file_in_tree"
		return 1
	}

	inodepaths | jq --argjson expected "$inodepaths" -r "$jqcompare" || return 1

	pass
}

function move_file_in_tree() {
	read -d '' inodepaths<<-EOF
	[
	  "$watched/agaric.mp4",
	  "$watched/phosphor.mp4",
	  "$watched/foo/quux/liberty.mp4"
	]
	EOF

	start "- expected inodepaths: $inodepaths"

	mv -v "$watched/foo/bar/liberty.mp4" "$watched/foo/quux"

	nodaemon -sync "$watched" || {
		fail "executing move_file_in_tree"
		return 1
	}

	inodepaths | jq --argjson expected "$inodepaths" -r "$jqcompare" || return 1

	pass
}

function non_unique_link() {
	read -d '' inodepaths<<-EOF
	[
	  "$watched/agaric.mp4",
	  "$watched/phosphor.mp4",
	  "$watched/foo/quux/liberty.mp4",
	  "$watched/one/two/three/liberty.mp4"
	]
	EOF
	read -d '' mediafiles<<-EOF
	[
	  "$watched/foo/quux/liberty.mp4",
	  "$watched/one/two/three/liberty.mp4"
	]
	EOF

	start "- expected inodepaths: $inodepaths and mediafiles: $mediafiles"

	ln -v "pool/liberty.mp4" "$watched/one/two/three"

	nodaemon -sync "$watched" || {
		fail "executing non_unique_link"
		return 1
	}

	inodepaths | jq --argjson expected "$inodepaths" -r "$jqcompare" || return 1

	findmediafiles value='Ben Franklin' \
	| jq --argjson expected "$mediafiles" -r "$jqcompare" || return 1

	pass
}

function cleanup_orphaned_trees() {
	read -d '' excludepaths<<-EOF
	[
	  "foo",
	  "bar",
	  "quux"
	]
	EOF

	start "- should not contain paths: $excludepaths"

	rm -v "$watched/foo/quux/liberty.mp4"

	nodaemon -sync "$watched" || {
		fail "executing move_file_in_tree"
		return 1
	}

	allpathnames | jq --argjson exclude "$excludepaths" -r "$jqnotcontains" || return 1

	pass
}

function fake_moved_from() {
	# removinb 'two' removes dependents 'three' and 'liberry,mp4' and
	# also leaves 'one' a leafless orphan, so it get's removed too;
	# note that the fule is still there - this is a *fake* move event
	read -d '' excludepaths<<-EOF
	[
	  "one",
	  "two",
	  "three",
	  "liberty.mp4"
	]
	EOF

	start "- should not contain paths: $excludepaths"

	cat <<-EOF|
	insert  into transients(cookie, oldpath, created)
	select  'cookie'
	       ,id
	       ,datetime(current_timestamp, '-1 minute')
	  from  paths
	 where  name = 'two'
	returning 'created transient', *
	EOF
	sqlite3 -bail -json "$db" || {
		fail "seeding data for fake_moved_from"
		return 1
	}

	nodaemon -sync "$watched" || {
		fail "fake_moved_from"
		return 1
	}

	allpathnames | jq --argjson exclude "$excludepaths" -r "$jqnotcontains" || return 1

	pass
}

function start_listener() {
	start "- should start listener"

	../bin/catalog "$watched"
	echo -n "sleeping while listener starts... "
	sleep .3s
	echo "done sleeping"

	pgrep -g "$$" || return 1

	pass
}

function check_status() {
	start "- should show sample service running"

	../bin/catalog -status "$watched" 2>&1 \
	| grep 'tests/sample' \
	| grep -q 'running' || return 1

	pass
}

function list_status() {
	start "- should show sample service running"

	../bin/catalog -list 2>&1 \
	| grep 'tests/sample' \
	| grep -q 'running' || return 1

	pass
}

function rebuild_while_running() {
	start "- should fail to start a sync process"

	../bin/catalog -rebuild "$watched" && return 1

	pass
}

function sync_while_running() {
	start "- should fail to start a sync process"

	../bin/catalog -sync "$watched" && return 1

	pass
}

function listen_while_running() {
	start "- should fail to start a listener process"

	../bin/catalog "$watched" && return 1

	pass
}

function force_listen() {
	start "- should succeed starting a new listener"

	../bin/catalog -force "$watched" || return 1

	pass
}

function listen_changes() {
	read -d '' inodepaths<<-EOF
	[
	  "$watched/foo/quux/liberty.mp4",
	  "$watched/one/two/morel.mp4",
	  "$watched/agaric.mp4"
	]
	EOF
	read -d '' mediafiles<<-EOF
	[
	  "$watched/foo/quux/liberty.mp4"
	]
	EOF

	start "- expected inodepaths: $inodepaths and mediafiles: $mediafiles"

	mv -v "$watched/one/two/three/liberty.mp4" "$watched/foo/quux"
	mv -v "$watched/phosphor.mp4" "$watched/.."
	rm -v "$watched/../phosphor.mp4"
	ln -v "pool/morel.mp4" "$watched/one/two"

	inodepaths | jq --argjson expected "$inodepaths" -r "$jqcompare" || return 1

	findmediafiles value='Ben Franklin' \
	| jq --argjson expected "$mediafiles" -r "$jqcompare" || return 1

	pass
}

function cleanup() {
	trees=(../{data,log,run}"$watched")

	start "- should remove trees for '${trees[@]}'"

	#../bin/catalog -remove "$watched" || return 1
	../bin/catalog -halt "$watched" || return 1

	find "${trees[@]}" 2>/dev/null && return 1

	pass
}

start "- full test suite..."

if ! sanity; then
	fail "setting up the test environment"
elif ! rebuild; then
	fail "rebuild"
elif ! link_one_from_pool; then
	fail "link_one_from_pool"
elif ! remove_file_in_tree; then
	fail "remove_file_in_tree"
elif ! move_file_in_tree; then
	fail "move_file_in_tree"
elif ! non_unique_link; then
	fail "non_unique_link"
elif ! cleanup_orphaned_trees; then
	fail "cleanup_orphaned_trees"
elif ! fake_moved_from; then
	fail "fake_moved_from"
elif ! start_listener; then
	fail "starting listener"
elif ! check_status; then
	fail "checking status"
elif ! list_status; then
	fail "listing status"
elif ! rebuild_while_running; then
	fail "rebuilding while running"
elif ! sync_while_running; then
	fail "syncing while running"
elif ! listen_while_running; then
	fail "listening while running"
elif ! force_listen; then
	fail "forcing a new listener"
#elif ! listen_changes; then
#	fail "listening for changes"
elif ! cleanup; then
	fail "removing a service"
else
	rm -rf "$watched" ./pool
	echo
	pass "... full test suite"
fi

